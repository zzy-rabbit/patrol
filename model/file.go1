package model

type FileType int

const (
	FileTypeImage FileType = iota + 1
	FileTypeVideo
	FileTypeAudio
)

type FileUpload struct {
	Type      FileType `json:"type"`
	Name      string   `json:"name"`
	MD5       string   `json:"md5"`
	TotalSize int      `json:"total_size"`
	PackSize  int      `json:"pack_size"`
	PackNum   int      `json:"pack_num"`
}
