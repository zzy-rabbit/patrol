package model

type FileType int

const (
	FileTypeImage FileType = iota + 1
	FileTypeVideo
	FileTypeAudio
)

type FileCommit struct {
	Session string   `json:"session"`
	Type    FileType `json:"type"`
}

type File struct {
	Identify
	Name string   `json:"name"`
	Type FileType `json:"type"`
	URL  string   `json:"url"`
	Mime string   `json:"mime"`
	Hash string   `json:"hash"`
	Size int64    `json:"size"`
}
