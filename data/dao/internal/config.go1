func (s *session) GetCheckPoints(ctx context.Context, condition model.CheckPointCondition) ([]model.CheckPoint, model.PageInfo, xerror.IError) {
	db := s.db
	if len(condition.IDs) > 0 {
		db = db.Where("identify in ?", condition.IDs)
	}
	if len(condition.Users) > 0 {
		db = db.Where("user in ?", condition.Users)
	}
	if len(condition.Serials) > 0 {
		db = db.Where("serial in ?", condition.Serials)
	}
	if !condition.TimeBefore.IsZero() {
		db = db.Where("util <= ?", condition.TimeBefore.Time.Format("2006-01-02T15:04:05-07:00"))
	}
	if !condition.TimeAfter.IsZero() {
		db = db.Where("util >= ?", condition.TimeAfter.Time.Format("2006-01-02T15:04:05-07:00"))
	}

	total := int64(0)
	if condition.PageQuery != nil && condition.PageQuery.Num > 0 && condition.PageQuery.Size > 0 {
		err := db.Count(&total).Error
		if xerror.Error(err) {
			s.logger.Error(ctx, "query checkPoints count by condition %+v fail %v", condition, err)
			return nil, model.PageInfo{}, transError(err)
		}
		offset := (condition.PageQuery.Num - 1) * condition.PageQuery.Size
		db = db.Offset(offset).Limit(condition.PageQuery.Size)
	}

	var tables []CheckPoint
	err := db.Find(&tables).Error
	if xerror.Error(err) {
		s.logger.Error(ctx, "query checkPoints by condition %+v fail %v", condition, err)
		return nil, model.PageInfo{}, transError(err)
	}
	checkPoints := make([]model.CheckPoint, 0, len(tables))
	for _, table := range tables {
		checkPoints = append(checkPoints, table.ToModel())
	}
	return checkPoints, model.PageInfo{
		Count: len(tables),
		Total: int(total),
	}, nil
}

