func (s *service) AddPoint(ctx *fiber.Ctx) error {
	var header bpmodel.Header
	var point model.Point
	xerr := s.IHttp.ParseBodyParams(ctx, &header, &point)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "parse body params fail %v", xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}
	department := ctx.Get("department")
	identify, xerr := s.IConfig.AddPoint(ctx.UserContext(), department, point)
	if xerror.Error(xerr) {
		s.ILogger.Error(ctx.UserContext(), "department %s add point %+v fail %v", department, point, xerr)
		return ctx.JSON(&bpmodel.HttpResponse{
			IError: xerr,
		})
	}
	return ctx.JSON(&bpmodel.HttpResponse{
		IError: xerror.ErrSuccess,
		Data:   identify,
	})
}

