package internal

import (
	"github.com/gofiber/fiber/v2"
)

func (s *service) registerRouter(fiberApp *fiber.App) {
	fileGroup := fiberApp.Group("/patrol/api/v1/file")
	fileGroup.Post("/commit", s.CommitFile)
	fileGroup.Delete("/revert", s.RevertFile)
	fileGroup.Delete("", s.DeleteFile)
	fileGroup.Get("", s.GetFile)
}
