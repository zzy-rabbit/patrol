package internal

import (
	"context"
	"github.com/gofiber/fiber/v2"
)

func (s *service) registerRouter(ctx context.Context, fiberApp *fiber.App) {
	userGroup := fiberApp.Group(
		"/user/api/v1/",
		s.IHttp.CORSMiddleware(),
		s.IHttp.TimingMiddleware(),
		s.IAuth.Middleware(ctx),
	)

	userGroup.Post("add", s.AddUser)
	userGroup.Post("update", s.UpdateUser)
	userGroup.Delete("", s.DeleteUsers)
	userGroup.Get("", s.GetUsers)
}
